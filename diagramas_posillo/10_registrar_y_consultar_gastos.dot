digraph G {
  graph [fontname="Helvetica", rankdir=LR, nodesep=0.55, ranksep=0.9, splines=ortho, bgcolor="white", labelloc="t"];
  node [fontname="Helvetica", shape=box, style="rounded,filled", color="#CBD5E1", penwidth=1.1, margin="0.10,0.06", fontsize=10];
  edge [fontname="Helvetica", color="#64748B", arrowsize=0.8, penwidth=1.1, fontsize=9];
  labelloc="t";
  label="Registrar gasto y consultar gastos por fecha";
  subgraph cluster_actor {
    label="Actor";
    color="#FDBA74";
    style="rounded";
  actor [label="Usuario con permiso de gastos", fillcolor="#FFF7ED", shape=oval];
  }
  subgraph cluster_view {
    label="Vista";
    color="#60A5FA";
    style="rounded";
  view_main [label="Expenses.tsx
filtrar rango / agregar gasto", fillcolor="#EFF6FF", shape=box];
  }
  subgraph cluster_controller {
    label="Controller";
    color="#A78BFA";
    style="rounded";
  preload [label="preload.ts
api.expenses.add / list", fillcolor="#F5F3FF", shape=box];
  ipc [label="expenses.ipc.ts
expenses:add / expenses:list", fillcolor="#F5F3FF", shape=box];
  }
  subgraph cluster_model {
    label="Model";
    color="#34D399";
    style="rounded";
  repo [label="expenses.repo.ts
addExpenseRepo / listExpensesRepo", fillcolor="#ECFDF5", shape=box];
  audit [label="audit repo
EXPENSE_CREATE", fillcolor="#ECFDF5", shape=box];
  }
  subgraph cluster_dao {
    label="DAO";
    color="#F59E0B";
    style="rounded";
  dao [label="addExpense / listExpenses
(o addExpenseMySql / listExpensesMySql)", fillcolor="#FEF3C7", shape=box];
  }
  subgraph cluster_data {
    label="Datos";
    color="#94A3B8";
    style="rounded";
  data [label="Tabla expenses + audit_logs", fillcolor="#F3F4F6", shape=box];
  }
  note1 [label="Expenses.tsx usa directamente window.api/ipc para listar y crear; el repositorio vuelve a decidir si usa SQLite o MySQL.", fillcolor="#F8FAFC", shape=note, color="#CBD5E1"];
  actor -> view_main [label="1. filtra fechas o crea gasto", color="#64748B", fontcolor="#64748B"];
  view_main -> preload [label="2. api.expenses.list/add", color="#4F46E5", fontcolor="#4F46E5"];
  preload -> ipc [label="3. expenses:list o expenses:add", color="#4F46E5", fontcolor="#4F46E5"];
  ipc -> repo [label="4. valida expenses:read/write", color="#7C3AED", fontcolor="#7C3AED"];
  repo -> dao [label="5. usa backend activo", color="#059669", fontcolor="#059669"];
  dao -> data [label="6. SELECT o INSERT expenses", color="#D97706", fontcolor="#D97706"];
  data -> dao [label="7. filas / id creado", color="#334155", fontcolor="#334155"];
  dao -> repo [label="8. respuesta repo", color="#059669", fontcolor="#059669"];
  ipc -> audit [label="9. si crea gasto => audit log", color="#059669", fontcolor="#059669"];
  audit -> data [label="10. inserta audit_logs", color="#334155", fontcolor="#334155"];
  ipc -> preload [label="11. respuesta IPC", color="#4F46E5", fontcolor="#4F46E5"];
  preload -> view_main [label="12. refresca listado y total", color="#4F46E5", fontcolor="#4F46E5"];
  note1 -> view_main [style=dashed, arrowhead=none, color="#94A3B8"];
}

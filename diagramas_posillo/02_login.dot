digraph G {
  graph [fontname="Helvetica", rankdir=LR, nodesep=0.55, ranksep=0.9, splines=ortho, bgcolor="white", labelloc="t"];
  node [fontname="Helvetica", shape=box, style="rounded,filled", color="#CBD5E1", penwidth=1.1, margin="0.10,0.06", fontsize=10];
  edge [fontname="Helvetica", color="#64748B", arrowsize=0.8, penwidth=1.1, fontsize=9];
  labelloc="t";
  label="Login de usuario";
  subgraph cluster_actor {
    label="Actor";
    color="#FDBA74";
    style="rounded";
  actor [label="Empleado / Cajero", fillcolor="#FFF7ED", shape=oval];
  }
  subgraph cluster_view {
    label="Vista";
    color="#60A5FA";
    style="rounded";
  view_main [label="Login.tsx
form email/password", fillcolor="#EFF6FF", shape=box];
  }
  subgraph cluster_controller {
    label="Controller";
    color="#A78BFA";
    style="rounded";
  service [label="services/auth.ts
login(email,password)", fillcolor="#F5F3FF", shape=box];
  preload [label="preload.ts
window.api", fillcolor="#F5F3FF", shape=box];
  ipc [label="auth.ipc.ts
auth:login + RBAC implícito", fillcolor="#F5F3FF", shape=box];
  }
  subgraph cluster_model {
    label="Model";
    color="#34D399";
    style="rounded";
  model [label="Autenticación
App.tsx guarda sesión
ChangePassword si mustChangePassword", fillcolor="#ECFDF5", shape=box];
  }
  subgraph cluster_dao {
    label="DAO";
    color="#F59E0B";
    style="rounded";
  dao [label="authUser (SQLite)
authUserMySql (MySQL)", fillcolor="#FEF3C7", shape=box];
  }
  subgraph cluster_data {
    label="Datos / salida";
    color="#94A3B8";
    style="rounded";
  data [label="Tabla users
password_hash + role", fillcolor="#F3F4F6", shape=box];
  }
  note1 [label="En este proyecto el login no tiene un service de negocio separado: el IPC auth llama directamente a authUser/authUserMySql y App.tsx decide si obliga cambio de contraseña.", fillcolor="#F8FAFC", shape=note, color="#CBD5E1"];
  actor -> view_main [label="1. escribe credenciales", color="#64748B", fontcolor="#64748B"];
  view_main -> service [label="2. login()", color="#4F46E5", fontcolor="#4F46E5"];
  service -> preload [label="3. api.auth.login", color="#4F46E5", fontcolor="#4F46E5"];
  preload -> ipc [label="4. auth:login", color="#4F46E5", fontcolor="#4F46E5"];
  ipc -> dao [label="5. busca usuario en backend activo", color="#059669", fontcolor="#059669"];
  dao -> data [label="6. consulta users + password_hash", color="#D97706", fontcolor="#D97706"];
  data -> dao [label="7. devuelve registro", color="#334155", fontcolor="#334155"];
  dao -> ipc [label="8. valida bcrypt y rol", color="#059669", fontcolor="#059669"];
  ipc -> preload [label="9. retorna user", color="#4F46E5", fontcolor="#4F46E5"];
  preload -> service [label="10. respuesta IPC", color="#4F46E5", fontcolor="#4F46E5"];
  service -> model [label="11. App.tsx setSessionUser", color="#059669", fontcolor="#059669"];
  model -> view_main [label="12. entra a AppRoutes o ChangePassword", color="#059669", fontcolor="#059669"];
  note1 -> view_main [style=dashed, arrowhead=none, color="#94A3B8"];
}

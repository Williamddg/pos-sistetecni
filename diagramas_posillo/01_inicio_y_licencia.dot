digraph G {
  graph [fontname="Helvetica", rankdir=LR, nodesep=0.55, ranksep=0.9, splines=ortho, bgcolor="white", labelloc="t"];
  node [fontname="Helvetica", shape=box, style="rounded,filled", color="#CBD5E1", penwidth=1.1, margin="0.10,0.06", fontsize=10];
  edge [fontname="Helvetica", color="#64748B", arrowsize=0.8, penwidth=1.1, fontsize=9];
  labelloc="t";
  label="Inicio del sistema + validación/activación de licencia";
  subgraph cluster_actor {
    label="Actor";
    color="#FDBA74";
    style="rounded";
  actor [label="Usuario", fillcolor="#FFF7ED", shape=oval];
  }
  subgraph cluster_view {
    label="Vista";
    color="#60A5FA";
    style="rounded";
  app [label="App.tsx
init: autodetect + setup + sesión", fillcolor="#EFF6FF", shape=box];
  guard [label="RequireLicense.tsx
checkOnline + status", fillcolor="#EFF6FF", shape=box];
  activate [label="Activate.tsx
formulario de licencia", fillcolor="#EFF6FF", shape=box];
  }
  subgraph cluster_controller {
    label="Controller";
    color="#A78BFA";
    style="rounded";
  preload [label="preload.ts
api.autodetect / api.license", fillcolor="#F5F3FF", shape=box];
  ipc_auto [label="autodetect.ipc.ts", fillcolor="#F5F3FF", shape=box];
  ipc_license [label="main.ts IPC
license:status / activate / check-online", fillcolor="#F5F3FF", shape=box];
  }
  subgraph cluster_model {
    label="Model";
    color="#34D399";
    style="rounded";
  license [label="license.ts
getMachineId, licenseStatusLocal,
activateOnline, checkOnline", fillcolor="#ECFDF5", shape=box];
  }
  subgraph cluster_dao {
    label="Persistencia / externo";
    color="#F59E0B";
    style="rounded";
  files [label="license.json + machine.json", fillcolor="#FEF3C7", shape=box];
  supabase [label="Supabase validate-license", fillcolor="#FCE7F3", shape=box];
  }
  subgraph cluster_data {
    label="Resultado";
    color="#94A3B8";
    style="rounded";
  route [label="/activate o rutas protegidas", fillcolor="#F3F4F6", shape=box];
  }
  note1 [label="El arranque real no solo muestra login: primero autodetecta MySQL, luego setup de negocio y finalmente licencia. Las rutas internas quedan bloqueadas por RequireLicense.", fillcolor="#F8FAFC", shape=note, color="#CBD5E1"];
  actor -> app [label="1. abre aplicación", color="#64748B", fontcolor="#64748B"];
  app -> preload [label="2. consulta autodetect / setup", color="#4F46E5", fontcolor="#4F46E5"];
  preload -> ipc_auto [label="3. invoke autodetect:status", color="#4F46E5", fontcolor="#4F46E5"];
  ipc_auto -> route [label="4. decide SetupWizard o modo ready", color="#059669", fontcolor="#059669"];
  app -> guard [label="5. entra a rutas protegidas", color="#64748B", fontcolor="#64748B"];
  guard -> preload [label="6. checkOnline + status", color="#4F46E5", fontcolor="#4F46E5"];
  preload -> ipc_license [label="7. IPC licencia", color="#4F46E5", fontcolor="#4F46E5"];
  ipc_license -> license [label="8. valida local / online", color="#059669", fontcolor="#059669"];
  license -> files [label="9a. lee/guarda estado local", color="#D97706", fontcolor="#D97706"];
  license -> supabase [label="9b. valida clave en servidor", color="#BE185D", fontcolor="#BE185D"];
  license -> route [label="10. ok => entra, no ok => /activate", color="#059669", fontcolor="#059669"];
  actor -> activate [label="11. ingresa licenseKey", color="#64748B", fontcolor="#64748B"];
  activate -> preload [label="12. api.license.activate", color="#4F46E5", fontcolor="#4F46E5"];
  preload -> ipc_license [label="13. license:activate", color="#4F46E5", fontcolor="#4F46E5"];
  ipc_license -> license [label="14. activateOnline", color="#059669", fontcolor="#059669"];
  license -> supabase [label="15. valida licencia y machineId", color="#BE185D", fontcolor="#BE185D"];
  license -> files [label="16. guarda lastCheckAt / expiresAt", color="#D97706", fontcolor="#D97706"];
  license -> route [label="17. habilita acceso", color="#059669", fontcolor="#059669"];
  note1 -> view_main [style=dashed, arrowhead=none, color="#94A3B8"];
}
